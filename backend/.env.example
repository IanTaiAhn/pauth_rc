# P-Auth RC Environment Configuration
# Copy this file to .env and update with your actual values

# ========================================
# LLM API Configuration
# ========================================
GROQ_API_KEY=your_groq_api_key_here

# ========================================
# Authentication & Security
# ========================================
# JWT secret key for signing tokens
# IMPORTANT: Generate a strong random key for production
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# JWT token expiration time in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Keys for service-to-service authentication
# Format: comma-separated list of valid API keys
# Example: key1,key2,key3
API_KEYS=your_api_key_1,your_api_key_2

# ========================================
# CORS Configuration
# ========================================
# Allowed origins for CORS (comma-separated)
# Development default: http://localhost:5173
# Production example: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Allow credentials (cookies, authorization headers) in CORS requests
# Set to "false" if not needed
CORS_ALLOW_CREDENTIALS=true

# ========================================
# Rate Limiting
# ========================================
# Default rate limit for unauthenticated requests
# Format: number/unit (e.g., 100/hour, 10/minute)
RATE_LIMIT_DEFAULT=100/hour

# Rate limit for authenticated requests (typically higher)
RATE_LIMIT_AUTHENTICATED=1000/hour

# Storage backend for rate limiting
# Options: memory:// (default, not distributed) or redis://localhost:6379
RATE_LIMIT_STORAGE_URI=memory://

# ========================================
# RAG Pipeline Configuration
# ========================================
# Path to local sentence transformer model
SENT_TRANSFORMER_MODEL=app/rag_pipeline/models/minilm

# Path to vector store directory
VECTOR_STORE_PATH=app/rag_pipeline/vectorstore

# Path to local Qwen2.5 model (if using local LLM)
MODEL_PATH=/path/to/qwen2.5/model

# ========================================
# Application Configuration
# ========================================
# Environment mode (development, staging, production)
ENVIRONMENT=development

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
